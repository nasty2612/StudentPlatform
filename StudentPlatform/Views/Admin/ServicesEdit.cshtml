@using StudentPlatform.Domain.Enums
@model Service
@{
    string strTitle = "Редактировать запись";
    ViewBag.Titlr = strTitle;
}
<style>
    button {
        color: black !important;
    }
</style>
<script src="https://cdn.tiny.cloud/1/e3f2xlqe1hl4x5gz5cn0mdgekpq4a7zy0jxkdcc3sqma3oad/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>
<div>
    <h2>
        @strTitle
    </h2>
    <div>
        <form asp-area="" asp-controller="Admin" asp-action="ServicesEdit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="DataCreated" />
            <input type="hidden" asp-for="Photo" />

            <div asp-validation-summary="All"></div>
            <div class="div-box">
                <select asp-for="ServiceCategoryId">
                    <option value="">...Выберите из списка...</option>
                    @foreach (ServiceCategory entity in ViewBag.ServiceCategories)
                    {
                        <option value="@entity.Id">@entity.Title</option>
                    }
                </select>
                <span asp-validation-for="ServiceCategoryId"></span>
            </div>
            <div class="div-box">
                <label asp-for="Title"></label>
                <input asp-for="Title" />
                <span asp-validation-for="Title"></span>
            </div>
            <div class="div-box">
                <label asp-for="Type"></label>
                <select asp-for="Type" asp-items="Html.GetEnumSelectList<ServiceTypeEnum>() "></select>
                <span asp-validation-for="Type"></span>
            </div>
            <div class="div-box">
                <label asp-for="DescriptionShort"></label>
                <input asp-for="DescriptionShort" />
                <span asp-validation-for="DescriptionShort"></span>
            </div>
            <div class="div-box">
                <label asp-for="Description"></label>
                <textarea asp-for="Description"></textarea>
                <span asp-validation-for="Description"></span>
            </div>
            <div class="div-box">
                <label asp-for="Photo"></label>
                <input type="file" name="titleImageFile" id="titleImageFile" />
                <div>
                    <img class="img-block" src="~/img/@Model.Photo"/>
                </div>
            </div>
            <input type="submit" value="Сохранить" />
        </form>
    </div>
</div>
<script>
    tinymce.init({
      selector: 'textarea',
      language: 'ru',
      plugins: 'anchor autolink charmap codesample emoticons image link lists media searchreplace table visualblocks wordcount',
      toolbar: 'undo redo | blocks fontfamily fontsize | bold italic underline strikethrough | link image media table | align lineheight | numlist bullist indent outdent | emoticons charmap | removeformat',
      automatic_uploads: true,
      images_upload_url: '/admin/SaveEditorImg',
      images_upload_filename: true,
      image_dimensions: false,
      paste_data_images: true,
      convert_urls: false
    });
</script>