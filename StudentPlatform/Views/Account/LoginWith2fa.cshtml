@model LoginWith2faViewModel
@{
    string strTitle = "Подтверждение входа";
    ViewBag.Title = strTitle;
}

<div>
    <h1>
        @strTitle
    </h1>
    <div class="div-box">
        <p>Ваш аккаунт защищен двухфакторной аутентификацией. Код подтверждения отправлен на вашу почту.</p>

        <form method="post" asp-route-returnUrl="@ViewBag.ReturnUrl">
            <div asp-validation-summary="All"></div>

            <div>
                <label asp-for="TwoFactorCode">Введите код из письма</label>
                <input asp-for="TwoFactorCode" autocomplete="off" />
                <span asp-validation-for="TwoFactorCode"></span>
            </div>
            <div style="margin-top: 15px;">
                <input type="submit" value="Подтвердить" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}